# ═══════════════════════════════════════════════════════════════
# Ausom Ukraine — environment variables template
# ═══════════════════════════════════════════════════════════════
# Скопіюй у .env.local і заповни реальними значеннями.
# .env.local ігнорується git'ом (див. .gitignore).

# ─── Public (exposed to the browser) ─────────────────────────
# Ці ключі віддаються клієнту, це нормально — для них працює RLS.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Канонічний URL сайту — використовується в sitemap.ts, robots.ts, OG tags
NEXT_PUBLIC_SITE_URL=https://ausom.in.ua

# ─── Server-only (NEVER prefix with NEXT_PUBLIC_) ────────────
# Service Role обходить RLS — суворо серверний.
# Використовується для admin-операцій і webhook'ів.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ─── Пізніше (коли будемо робити checkout/notifications) ─────
# RESEND_API_KEY=re_...
# LIQPAY_PUBLIC_KEY=sandbox_i...
# LIQPAY_PRIVATE_KEY=sandbox_...
# NOVAPOSHTA_API_KEY=...
